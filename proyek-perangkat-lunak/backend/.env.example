# Backend Express Environment Variables

# Database Configuration
DATABASE_URL=mysql://user:password@localhost:3306/taskplanner

# Server Configuration
PORT=8000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Frontend Configuration
FRONTEND_URL=http://localhost:5173

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# WhatsApp Integration (Optional)
TOKEN_WHATSAPP=your-whatsapp-token
WHATSAPP_BOT_URL=https://your-whatsapp-bot-url.com

# AI Configuration (9Router or OpenAI-compatible endpoint)
NINE_ROUTER_API=https://your-ai-endpoint.com/v1/chat/completions
NINE_ROUTER_API_KEY=your-ai-api-key
NINE_ROUTER_MODEL=cx/gpt-5.2

# Cloudflare Turnstile (Optional CAPTCHA)
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# Production with Cloudflare Tunnel (uncomment and update)
# FRONTEND_URL=https://app.yourdomain.com
# GOOGLE_REDIRECT_URI=https://api.yourdomain.com/api/auth/google/callback
