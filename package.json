{
  "name": "smart-task-planner",
  "version": "0.1.0",
  "description": "Smart Task Planner - Universal task management with AI-powered priority scheduling",
  "homepage": "https://taskplanner.dastrevas.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/bayufrd/taskplanner.git"
  },
  "author": "BayuFrd",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build && npm run prisma:generate",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:prod": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "db:push": "prisma db push",
    "db:seed": "node scripts/seed.js"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "next": "^14.0.0",
    "@prisma/client": "^5.7.0",
    "next-auth": "^4.24.0",
    "axios": "^1.6.0",
    "zustand": "^4.4.0",
    "date-fns": "^2.30.0",
    "clsx": "^2.0.0",
    "google-auth-library": "^9.6.0",
    "googleapis": "^118.0.0",
    "dotenv": "^16.3.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.3.0",
    "prisma": "^5.7.0",
    "eslint": "^8.54.0",
    "eslint-config-next": "^14.0.0"
  }
}
