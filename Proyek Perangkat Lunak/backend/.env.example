# Database Configuration
# Format: mysql://username:password@host:port/database
DATABASE_URL="mysql://root:password@192.168.1.2:3307/taskplanner"

# Server Configuration
PORT=8000
NODE_ENV=development

# JWT Authentication
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# CORS Configuration
# Must match your Next.js frontend URL
FRONTEND_URL=http://localhost:3000
# Production: FRONTEND_URL=https://taskplanner.dastrevas.com

# Google OAuth Configuration
# Get credentials from Google Cloud Console: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Redirect URI will be auto-generated as: {FRONTEND_URL}/api/auth/google/callback
# Make sure to add this URI to Google OAuth authorized redirect URIs
