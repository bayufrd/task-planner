# ============================================
# Database Configuration
# ============================================
# Prisma Database URL (direct connection string)
# Format: mysql://username:password@host:port/database
DATABASE_URL="mysql://root:password@192.168.1.2:3307/taskplanner"

# ============================================
# NextAuth Configuration
# ============================================
# Generate secure secret:
# Command: openssl rand -base64 32 (macOS/Linux)
# Online: https://generate-secret.vercel.app/32
# Keep this SECRET - never commit to git!
NEXTAUTH_SECRET=your_nextauth_secret_here_generate_with_openssl
NEXTAUTH_URL=http://localhost:3000

# ============================================
# Google OAuth Configuration
# ============================================
# APPROACH: Multi-User Google OAuth (Recommended for MVP)
# 
# Benefits:
# ✅ Each user authenticates with their own Google account
# ✅ Each user can sync tasks to their own Google Calendar
# ✅ No shared API key - fully secured
# ✅ Seamless Google Calendar integration (create/edit/delete)
# ✅ No offline access needed - real-time sync
#
# Setup at Google Cloud Console: https://console.cloud.google.com
# 
# Steps:
# 1. Create New Project: "Smart Task Planner"
# 2. Enable APIs:
#    - Google Calendar API (for calendar operations)
# 3. Create OAuth 2.0 Credentials:
#    - Go to: Credentials > Create Credentials > OAuth client ID
#    - Select: Web application
#    - Authorized JavaScript origins:
#      * http://localhost:3000 (development)
#      * https://your-zero-trust-tunnel-url.com (production)
#    - Authorized redirect URIs:
#      * http://localhost:3000/api/auth/callback/google (development)
#      * https://your-zero-trust-tunnel-url.com/api/auth/callback/google (production)
# 4. Copy Client ID & Client Secret below

# Google OAuth Client ID
# Found at: Google Cloud Console > Credentials > OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com

# Google OAuth Client Secret
# Found at: Google Cloud Console > Credentials > OAuth 2.0 Client IDs
# KEEP THIS SECRET - Never commit to git!
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Google OAuth Scopes (automatic with NextAuth - no need to configure)
# - openid: Basic OpenID Connect
# - profile: User name and picture
# - email: User email address
# - https://www.googleapis.com/auth/calendar: Full calendar access (create/edit/delete)

# ============================================
# Backend Configuration
# ============================================
# Frontend URL for CORS (used by backend)
FRONTEND_URL=http://localhost:3000

# Next.js Public API URL (points to backend Express)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Environment mode
NODE_ENV=development

# ============================================
# Optional: Email Notifications
# ============================================
# For future use - send task reminders via email
# Get Gmail App Password:
# 1. Go to: https://myaccount.google.com/security
# 2. Enable 2-Step Verification
# 3. Go to: App passwords > Select "Mail" and "Windows Computer"
# 4. Copy the 16-digit app password

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_16_digit_app_password

NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_site_key